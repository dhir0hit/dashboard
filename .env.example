# Copy this file to `.env` (at the repo root) and edit before running
# `docker compose --env-file .env up --build`. Values here are picked up
# automatically by docker compose when a plain `.env` exists next to
# docker-compose.yml.

# --- User-facing port ---------------------------------------------------------
# The single published port the dashboard is reachable on.
DASHBOARD_PORT=8888

# --- Proxmox connection -------------------------------------------------------
PROXMOX_API_URL=https://proxmox.local:8006/
# Format: user!tokenid=secret  (the `!` and `=` MUST be preserved)
PROXMOX_API_TOKEN=root@pam!dashboard=00000000-0000-0000-0000-000000000000
PROXMOX_VERIFY_TLS=false
# Leave empty to auto-pick the first reachable node.
PROXMOX_NODE=

# --- SSH for in-guest Docker discovery (optional) -----------------------------
SSH_HOST=
SSH_PORT=22
SSH_USER=root
# Path INSIDE the backend container to an SSH private key. If you want to use
# a key from the host, mount it as a volume (e.g. add `-v ~/.ssh:/ssh:ro` in
# an override file) and set SSH_KEY_FILE=/ssh/id_ed25519.
SSH_KEY_FILE=
SSH_PASSWORD=

# --- Mode ---------------------------------------------------------------------
# Set to `true` for a dry run with mock services (no Proxmox host required).
# Set to `false` to query a real Proxmox host. `docker compose up` defaults to
# `true` so the stack boots out of the box; flip it once your token works.
MOCK=true

# --- Docker socket ------------------------------------------------------------
# Path on the HOST to the Docker socket. The backend mounts this so it can
# discover containers running directly on the host. Set to `/dev/null` to
# effectively disable host-Docker discovery.
DOCKER_SOCK=/var/run/docker.sock