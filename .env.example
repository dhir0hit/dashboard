# Copy this file to `.env` (at the repo root) and edit before running
# `docker compose --env-file .env up --build`. Values here are picked up
# automatically by docker compose when a plain `.env` exists next to
# docker-compose.yml.

# --- User-facing port ---------------------------------------------------------
# The single published port the dashboard is reachable on.
DASHBOARD_PORT=8888

# --- Mode ---------------------------------------------------------------------
# Set to `true` for a dry run with mock services (no Docker host required).
# Set to `false` to query a real Docker host. `docker compose up` defaults to
# `true` so the stack boots out of the box; flip it once your Docker socket works.
MOCK=true

# --- Docker socket ------------------------------------------------------------
# Path on the HOST to the Docker socket. The backend mounts this so it can
# discover containers running directly on the host. Set to `/dev/null` to
# effectively disable host-Docker discovery.
DOCKER_SOCK=/var/run/docker.sock

# --- Google Calendar sync (optional) ------------------------------------------
# OAuth is handled entirely in the FRONTEND (Desktop-app client + PKCE). Set
# VITE_GOOGLE_CLIENT_ID in frontend/.env (see frontend/.env.example).
# The backend takes the access_token via Bearer header on /api/calendar/google/sync.
