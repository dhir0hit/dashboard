# Docker socket path (auto-detected if not set)
DOCKER_SOCKET=/var/run/docker.sock

# Enable mock mode (no real Docker host required). MOCK=true wins regardless.
MOCK=false

# SQLite path for /api/config persistence.
CONFIG_DB=data/config.db

# --- Google Calendar sync (optional) -----------------------------------
# OAuth is now handled in the FRONTEND (Authorization Code + PKCE). Create a
# "Desktop app" OAuth client in Google Cloud Console and set VITE_GOOGLE_CLIENT_ID
# in frontend/.env (no client_secret anywhere — see frontend/.env.example).
# The backend only needs the access_token sent by the browser on each /sync call.

# Server
HOST=127.0.0.1
PORT=8000
