# Proxmox API endpoint, e.g. https://proxmox.example.com:8006/
PROXMOX_API_URL=https://proxmox.local:8006/

# API token: <user>!<token_id>=<secret>. The `!` and `=` MUST be preserved.
PROXMOX_API_TOKEN=root@pam!dashboard=00000000-0000-0000-0000-000000000000

# Verify TLS certificate. Set to false if using a self-signed cert for dev.
PROXMOX_VERIFY_TLS=false

# Node name (the PVE node to query). Defaults to first reachable node.
PROXMOX_NODE=

# --- SSH for in-guest Docker discovery ----------------------------------
# If using SSH (Docker socket not directly exposed to the host), provide a
# private key. For LXC, the backend falls back to `pct exec <vmid> -- docker ...`
# when SSH_HOST/SSH_USER are empty.
SSH_HOST=
SSH_PORT=22
SSH_USER=root
SSH_KEY_FILE=
SSH_PASSWORD=

# Enable mock mode (no real Proxmox required). MOCK=true wins regardless.
MOCK=false

# SQLite path for /api/config persistence.
CONFIG_DB=data/config.db

# --- Google Calendar sync (optional) -----------------------------------
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Add the redirect URI (default: http://localhost:8888/api/calendar/google/callback)
# to the Authorized redirect URIs list.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8888/api/calendar/google/callback

# Server
HOST=127.0.0.1
PORT=8000