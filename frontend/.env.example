# Frontend environment variables — copy to frontend/.env for local dev.
# In Docker, these are baked into the SPA at build time (vite).

# Backend API base URL. Leave EMPTY in dev (vite dev-proxy handles /api)
# and set to the absolute URL when the frontend is served from a different origin.
# VITE_API_BASE=

# Google OAuth client_id for the Calendar page's "Connect Google" button.
# Create a Desktop-app OAuth client (NOT "Web application") at
# https://console.cloud.google.com/apis/credentials — Desktop clients have no
# secret and let the browser exchange the auth code directly with Google using
# PKCE. The redirect URI http://localhost:5173/calendar (dev) and
# http://localhost:8888/calendar (prod) is accepted without pre-registration.
VITE_GOOGLE_CLIENT_ID=
